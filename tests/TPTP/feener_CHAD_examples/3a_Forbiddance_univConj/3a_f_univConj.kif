; CF 
; 3a_f_univconj.kif

; Prohibition 1: "If Bill is at the office, prohibited to smoke"
 (=> 
   (and 
     (instance ?OB OfficeBuilding)
     (located Bill ?OB))
   (modalAttribute
     (exists (?SMOK)
       (and
         (instance ?SMOK Smoking)
         (located ?SMOK ?OB)
         (agent ?SMOK Bill))) Prohibition))

; Prohibition 2: "If Bill smokes at the office, prohibited from going on 
; business trip"
 (=> 
   (and
     (instance ?SMOK Smoking)
     (instance ?OB OfficeBuilding)
     (agent ?SMOK Bill)
     (located ?SMOK ?OB))
   (modalAttribute 
     (exists (?BT)
       (and
         (instance ?BT BusinessTrip)
         (agent ?BT Bill))) Prohibition))

; Option A: "Bill is at the office"
 (exists (?OB)
   (and 
     (instance ?OB OfficeBuilding)
     (located Bill ?OB)))

; Option B: "Bill is not"
 (not (exists (?OB)
   (and 
     (instance ?OB OfficeBuilding)
     (located Bill ?OB))))

; Conjecture: "Therefore, Bill may not go on business trip"
 (modalAttribute 
   (exists (?BT)
     (and 
       (instance ?BT BusinessTrip)
       (agent ?BT Bill))) Prohibition)