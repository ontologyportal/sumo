% CF 
% 4c_Obligation_then_Permission_twoHopConjecture.thf
% Results under Systems D4 (for O) and D (for P)
% Changed conjecture to explicitly require two hops (one for the chain 
% of obligations, one for a single permission) 

% Option A: 
% D4, D, and bridge : ref (but no sysD under P)
% D4 and bridge     : ref
% D4 and D          : ref (using all 3 axioms w/o bridge)
% Summary: Successfully works under the full system. Interestingly, it 
% could also work without bridge since the theorem prover found other 
% paths to refutation 

% Option B under full system: timeout 
% Summary: Correct and expected 

%%%%%%%%%%%%%%%%%%%%%%%%%% Pre-System Setup %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
thf(worlds_tp,type, w: $tType).
thf(cw_tp,type, cw: w).
thf(modals_tp,type, m: $tType).
thf(obligation_tp,type, s__Obligation: m).          % Using both O and P
thf(permission_tp, type, s__Permission: m).
thf(prohibition_tp, type, s__Prohibition: m).
thf(accreln1_tp,type, accreln1: m > w > w > $o ).
thf(accreln2_tp,type, accreln2: m > $i > w > w > $o ).
thf(accreln3_tp,type, accreln3: m > $i > $i > w > w > $o ).

%%%%%%%%%%%%% Separate systems under Obligation and Permission %%%%%%%%%%%%%

% System D4 under Obligaton: Serial and Transitive 
thf(serial_obligation, axiom,
  ![W1:w]: ?[W2:w]:
    (accreln1 @ s__Obligation @ W1 @ W2)).
thf(transitive_obligation, axiom,
  ![W1: w, W2: w, W3: w] :
    (((accreln1 @ s__Obligation @ W1 @ W2) &
      (accreln1 @ s__Obligation @ W2 @ W3))
     => (accreln1 @ s__Obligation @ W1 @ W3))).

% System D under Permission 
thf(serial_permission, axiom,
  ![W1:w]: ?[W2:w]:
    (accreln1 @ s__Permission @ W1 @ W2)).
    
% O-P Axiom
% (=>
%   (modalAttribute ?F Obligation)
%   (modalAttribute ?F Permission))
thf(bridge_obligation_permission, axiom,
  ![W1:w, W2:w]:
    ((accreln1 @ s__Obligation @ W1 @ W2)
     => (accreln1 @ s__Permission @ W1 @ W2))).
     
% Modality distinctness:
thf(dist_obligation_permission, axiom,  ~(s__Obligation = s__Permission)).
thf(dist_obligation_prohibition, axiom, ~(s__Obligation = s__Prohibition)).
thf(dist_permission_prohibition, axiom, ~(s__Permission = s__Prohibition)).
      
%%%%%%%%%%%%%%%%%%%%%%%%%%% End of Systems %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Relations:
thf(instance_t, type, s__instance:($i > $i > $o)). 
thf(agent_t, type, s__agent:($i > $i > w > $o)). 
thf(patient_t, type, s__patient: ($i > $i > w > $o)).
thf(destination_t, type, s__destination: ($i > $i > w > $o)).
thf(located_t, type, s__located: ($i > $i > w > $o)).

% Terms:
thf(human_t,       type, s__Human:         $i).
thf(paycheck_t,    type, s__PayCheck:      $i).
thf(giving_t,      type, s__Giving:        $i).
thf(tax_t,         type, s__Tax:           $i).
thf(driving_t,     type, s__Driving:       $i).
thf(officebuilding_t, type, s__OfficeBuilding: $i).
thf(keeping_t,     type, s__Keeping:       $i).
thf(parkinglot_t,  type, s__ParkingLot:    $i).

% Distinctness:
thf(dist_driving_giving, axiom, ~(s__Driving = s__Giving)).
thf(dist_driving_human, axiom, ~(s__Driving = s__Human)).
thf(dist_driving_keeping, axiom, ~(s__Driving = s__Keeping)).
thf(dist_driving_officebuilding, axiom, ~(s__Driving = s__OfficeBuilding)).
thf(dist_driving_parkinglot, axiom, ~(s__Driving = s__ParkingLot)).
thf(dist_driving_paycheck, axiom, ~(s__Driving = s__PayCheck)).
thf(dist_driving_tax, axiom, ~(s__Driving = s__Tax)).
thf(dist_giving_human, axiom, ~(s__Giving = s__Human)).
thf(dist_giving_keeping, axiom, ~(s__Giving = s__Keeping)).
thf(dist_giving_officebuilding, axiom, ~(s__Giving = s__OfficeBuilding)).
thf(dist_giving_parkinglot, axiom, ~(s__Giving = s__ParkingLot)).
thf(dist_giving_paycheck, axiom, ~(s__Giving = s__PayCheck)).
thf(dist_giving_tax, axiom, ~(s__Giving = s__Tax)).
thf(dist_human_keeping, axiom, ~(s__Human = s__Keeping)).
thf(dist_human_officebuilding, axiom, ~(s__Human = s__OfficeBuilding)).
thf(dist_human_parkinglot, axiom, ~(s__Human = s__ParkingLot)).
thf(dist_human_paycheck, axiom, ~(s__Human = s__PayCheck)).
thf(dist_human_tax, axiom, ~(s__Human = s__Tax)).
thf(dist_keeping_officebuilding, axiom, ~(s__Keeping = s__OfficeBuilding)).
thf(dist_keeping_parkinglot, axiom, ~(s__Keeping = s__ParkingLot)).
thf(dist_keeping_paycheck, axiom, ~(s__Keeping = s__PayCheck)).
thf(dist_keeping_tax, axiom, ~(s__Keeping = s__Tax)).
thf(dist_officebuilding_parkinglot, axiom, ~(s__OfficeBuilding = s__ParkingLot)).
thf(dist_officebuilding_paycheck, axiom, ~(s__OfficeBuilding = s__PayCheck)).
thf(dist_officebuilding_tax, axiom, ~(s__OfficeBuilding = s__Tax)).
thf(dist_parkinglot_paycheck, axiom, ~(s__ParkingLot = s__PayCheck)).
thf(dist_parkinglot_tax, axiom, ~(s__ParkingLot = s__Tax)).
thf(dist_paycheck_tax, axiom, ~(s__PayCheck = s__Tax)).

% Globals: "Bill is a human"
thf(bill_t, type, s__Bill: $i).
thf(bill_is_human, axiom,
  (s__instance @ s__Bill @ s__Human)). 

% Obligation 1: "If Bill gets a paycheck, must pay taxes"
%(=>
%  (and
%    (instance ?PC PayCheck)
%    (destination ?PC Bill))
%  (modalAttribute 
%    (exists (?G ?T)
%      (and
%        (instance ?G Giving)
%        (instance ?T Tax)
%        (agent ?G Bill)
%        (patient ?G ?T))) Obligation))
thf(obligation1_pay_taxes, axiom, (
  ![W1:w, W2: w] : 
  ( ![PC: $i]: (
    ((s__instance @ PC @ s__PayCheck) &
    (s__destination @ PC @ s__Bill @ W1)) => (
        (accreln1 @ s__Obligation @ W1 @ W2) => 
          (?[G: $i, T: $i] : (
            (s__instance @ G @ s__Giving) & 
            (s__instance @ T @ s__Tax) &
            (s__agent @ G @ s__Bill @ W2) & 
            (s__patient @ G @ T @ W2)))))))).

% Obligation 2: "If pay taxes, must drive to office"
%(=> 
%  (and
%    (instance ?G Giving)
%    (instance ?T Tax)
%    (agent ?G Bill)
%    (patient ?G ?T))
%  (modalAttribute 
%    (exists (?D ?OB) 
%      (and 
%        (instance ?D Driving)
%        (instance ?OB OfficeBuilding)
%        (agent ?D Bill)
%        (destination ?D ?OB))) Obligation))
thf(obligation2_drive_to_office, axiom, (
  ![W1:w, W2: w] : 
  ( ![G: $i, T: $i]: (
    ((s__instance @ G @ s__Giving) &
    (s__instance @ T @ s__Tax) & 
    (s__agent @ G @ s__Bill @ W1) & 
    (s__patient @ G @ T @ W1)) => (
        (accreln1 @ s__Obligation @ W1 @ W2) => 
          (?[D: $i, OB: $i] : (
            (s__instance @ D @ s__Driving) & 
            (s__instance @ OB @ s__OfficeBuilding) &
            (s__agent @ D @ s__Bill @ W2) & 
            (s__destination @ D @ OB @ W2)))))))).

% Permission: "If Bill drives to office, may park in lot" 
%(=>
%  (and
%    (instance ?D Driving)
%    (instance ?OB OfficeBuilding)
%    (agent ?D Bill)
%    (destination ?D ?OB))
%  (modalAttribute 
%    (exists (?PARK ?PL)
%      (and
%        (instance ?PARK Keeping)
%        (instance ?PL ParkingLot)
%        (agent ?PARK Bill)
%        (located ?PARK ?PL))) Permission))
thf(permission_park_in_lot, axiom, (
  ![W1:w, W2: w] : 
  ( ![D: $i, OB: $i]: (
    ((s__instance @ D @ s__Driving) & 
    (s__instance @ OB @ s__OfficeBuilding) &
    (s__agent @ D @ s__Bill @ W1) & 
    (s__destination @ D @ OB @ W1)) => (
      (accreln1 @ s__Permission @ W1 @ W2) => 
          (?[PARK: $i, PL: $i] : (
            (s__instance @ PARK @ s__Keeping) & 
            (s__instance @ PL @ s__ParkingLot) &
            (s__agent @ PARK @ s__Bill @ W2) & 
            (s__located @ PARK @ PL @ W2)))))))).

% Option A: "Bill gets a paycheck" 
%(exists (?PC)
%  (and
%    (instance ?PC PayCheck)
%    (destination ?PC Bill)))
thf(optionA_bill_gets_paycheck, axiom, (
  ?[PC: $i]: (
    ((s__instance @ PC @ s__PayCheck) &
    (s__destination @ PC @ s__Bill @ cw))))).

% Option B: "Bill doesn't" 
%(not (exists (?PC)
%  (and
%    (instance ?PC PayCheck)
%    (destination ?PC Bill))))
%thf(optionB_bill_no_paycheck, axiom, (
%  ~?[PC: $i]: (
%    ((s__instance @ PC @ s__PayCheck) &
%    (s__destination @ PC @ s__Bill @ cw))))).
            
% Conjecture: "Therefore, Bill may park in lot"
% (modalAttribute 
%   (exists (?PARK ?PL)
%     (and 
%       (instance ?PARK Keeping)
%       (instance ?PL ParkingLot)
%       (agent ?PARK Bill)
%       (located ?PARK ?PL))) Permission)
thf(conjecture_is_permitted, conjecture, (
  ?[Wi: w, Wx: w] : (
    (accreln1 @ s__Obligation @ cw @ Wi) & 
    (accreln1 @ s__Permission @ Wi @ Wx) & 
      (?[PARK: $i, PL: $i] : ( 
        (s__instance @ PARK @ s__Keeping) &
        (s__instance @ PL @ s__ParkingLot) &
        (s__agent @ PARK @ s__Bill @ Wx) &
        (s__located @ PARK @ PL @ Wx)))))).            
