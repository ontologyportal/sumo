% CF 
% 8_confersObligation.thf 

% Based on example 1f. Should behave the same. This is mainly to test 
% the SUMO mechanic for normative authority included in the deontic 
% statements.

% Option A: ref (o1, fact, o2, sysd4-o)
% Option B: timeout
% Summary of findings: This works like example 1. Expected and SUCCESS! 

%%%%%%%%%%%%%%%%%%%%%%%%%% Pre-System Setup %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
thf(worlds_tp,type, w: $tType).
thf(cw_tp,type, cw: w).
thf(modals_tp,type, m: $tType).
thf(obligation_tp,type, s__Obligation: m).          % obligation modality
thf(permission_tp, type, s__Permission: m).
thf(prohibition_tp, type, s__Prohibition: m).
thf(confersObligation_tp, type, s__confersObligation: m).
thf(confersRight_tp, type, s__confersRight: m).
thf(deprivesNorm_tp, type, s__deprivesNorm: m).
thf(hPFA_tp, type, s__hasPurposeForAgent: m).
thf(confersNorm_tp, type, s__confersNorm: m).
thf(accreln1_tp,type, accreln1: m > w > w > $o ).
thf(accreln2_tp,type, accreln2: m > $i > w > w > $o ).
thf(accreln3_tp,type, accreln3: m > $i > $i > w > w > $o ).
thf(accreln3_norm_tp, type, accreln3_norm: m > $i > m > w > w > $o).

% Distinct modal terms: 
thf(dist_obl_per,  axiom, ~(s__Obligation = s__Permission)).
thf(dist_obl_pro,  axiom, ~(s__Obligation = s__Prohibition)).
thf(dist_obl_co,   axiom, ~(s__Obligation = s__confersObligation)).
thf(dist_obl_cr,   axiom, ~(s__Obligation = s__confersRight)).
thf(dist_obl_dn,   axiom, ~(s__Obligation = s__deprivesNorm)).
thf(dist_obl_hpfa, axiom, ~(s__Obligation = s__hasPurposeForAgent)).
thf(dist_obl_cn,   axiom, ~(s__Obligation = s__confersNorm)).
thf(dist_per_pro,  axiom, ~(s__Permission = s__Prohibition)).
thf(dist_per_co,   axiom, ~(s__Permission = s__confersObligation)).
thf(dist_per_cr,   axiom, ~(s__Permission = s__confersRight)).
thf(dist_per_dn,   axiom, ~(s__Permission = s__deprivesNorm)).
thf(dist_per_hpfa, axiom, ~(s__Permission = s__hasPurposeForAgent)).
thf(dist_per_cn,   axiom, ~(s__Permission = s__confersNorm)).
thf(dist_pro_co,   axiom, ~(s__Prohibition = s__confersObligation)).
thf(dist_pro_cr,   axiom, ~(s__Prohibition = s__confersRight)).
thf(dist_pro_dn,   axiom, ~(s__Prohibition = s__deprivesNorm)).
thf(dist_pro_hpfa, axiom, ~(s__Prohibition = s__hasPurposeForAgent)).
thf(dist_pro_cn,   axiom, ~(s__Prohibition = s__confersNorm)).
thf(dist_co_cr,    axiom, ~(s__confersObligation = s__confersRight)).
thf(dist_co_dn,    axiom, ~(s__confersObligation = s__deprivesNorm)).
thf(dist_co_hpfa,  axiom, ~(s__confersObligation = s__hasPurposeForAgent)).
thf(dist_co_cn,    axiom, ~(s__confersObligation = s__confersNorm)).
thf(dist_cr_dn,    axiom, ~(s__confersRight = s__deprivesNorm)).
thf(dist_cr_hpfa,  axiom, ~(s__confersRight = s__hasPurposeForAgent)).
thf(dist_cr_cn,    axiom, ~(s__confersRight = s__confersNorm)).
thf(dist_dn_hpfa,  axiom, ~(s__deprivesNorm = s__hasPurposeForAgent)).
thf(dist_dn_cn,    axiom, ~(s__deprivesNorm = s__confersNorm)).
thf(dist_hpfa_cn,  axiom, ~(s__hasPurposeForAgent = s__confersNorm)).

%%%%%%%%%%%%%%%%%%%% Systems: Under confersObligation %%%%%%%%%%%%%%%%%%%%%

thf(serial_confersObligation, axiom,
  ![W1:w, A:$i, B:$i]: ?[W2:w]:
    (accreln3 @ s__confersObligation @ A @ B @ W1 @ W2)).

thf(transitive_confersObligation, axiom,
  ![W1: w, W2: w, W3: w, A:$i, B:$i] :
    (((accreln3 @ s__confersObligation @ A @ B @ W1 @ W2) &
      (accreln3 @ s__confersObligation @ A @ B @ W2 @ W3))
     => (accreln3 @ s__confersObligation @ A @ B @ W1 @ W3))).
     
%%%%%%%%%%%%%%%%%%%%%%%%%%%%% End: Systems %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Relations: 
thf(instance_t, type, s__instance:($i > $i > $o)).
thf(agent_t, type, s__agent:($i > $i > w > $o)).
thf(patient_t, type, s__patient: ($i > $i > w > $o)).
thf(origin_t, type, s__origin: ($i > $i > w > $o)).
thf(destination_t, type, s__destination: ($i > $i > w > $o)).

% Terms: 
thf(flying_t, type, s__Flying: $i).
thf(human_t, type, s__Human: $i).
thf(grocerystore_t, type, s__GroceryStore: $i).
thf(moon_t, type, s__Moon: $i).
thf(giving_t, type, s__Giving: $i).
thf(paycheck_t, type, s__PayCheck: $i).
thf(tax_t, type, s__Tax: $i).

% Globals: 
thf(bill_t, type, s__Bill: $i).
thf(bill_always_human, axiom, (
  s__instance @ s__Bill @ s__Human)).
thf(usGovernment_t, type, s__USGovernment: $i).
thf(usg_alwaysusg, axiom, (
  s__instance @ s__USG @ s__USGovernment)).

% Distinctness: 
thf(dist_moon_usg,       axiom, ~(s__Moon = s__USGovernment)).
thf(dist_moon_flying,    axiom, ~(s__Moon = s__Flying)).
thf(dist_moon_giving,    axiom, ~(s__Moon = s__Giving)).
thf(dist_moon_paycheck,  axiom, ~(s__Moon = s__PayCheck)).
thf(dist_moon_human,     axiom, ~(s__Moon = s__Human)).
thf(dist_moon_tax,       axiom, ~(s__Moon = s__Tax)).
thf(dist_usg_flying,     axiom, ~(s__USGovernment = s__Flying)).
thf(dist_usg_giving,     axiom, ~(s__USGovernment = s__Giving)).
thf(dist_usg_paycheck,   axiom, ~(s__USGovernment = s__PayCheck)).
thf(dist_usg_human,      axiom, ~(s__USGovernment = s__Human)).
thf(dist_usg_tax,        axiom, ~(s__USGovernment = s__Tax)).
thf(dist_flying_giving,  axiom, ~(s__Flying = s__Giving)).
thf(dist_flying_paycheck,axiom, ~(s__Flying = s__PayCheck)).
thf(dist_flying_human,   axiom, ~(s__Flying = s__Human)).
thf(dist_flying_tax,     axiom, ~(s__Flying = s__Tax)).
thf(dist_giving_paycheck,axiom, ~(s__Giving = s__PayCheck)).
thf(dist_giving_human,   axiom, ~(s__Giving = s__Human)).
thf(dist_giving_tax,     axiom, ~(s__Giving = s__Tax)).
thf(dist_paycheck_human, axiom, ~(s__PayCheck = s__Human)).
thf(dist_paycheck_tax,   axiom, ~(s__PayCheck = s__Tax)).
thf(dist_human_tax,      axiom, ~(s__Human = s__Tax)).

% Obligation 1: "US Gov confers on Bill, that if Bill gets a paycheck, 
% he must pay taxes"
%(=> 
%  (and 
%    (instance ?GIV Giving) 
%    (instance ?PCH PayCheck)
%    (instance ?USG USGovernment)
%    (patient ?GIV ?PCH) 
%    (destination ?GIV Bill))
%  (confersObligation ?USG Bill 
%    (exists (?TAX) 
%      (and 
%        (instance ?TAX Tax)
%        (origin ?TAX Bill)))))
thf(obligation1_bill_taxed, axiom,
  ![W1:w, W2: w] : 
  ( ![GIV: $i, PCH: $i] : (( 
      (s__instance @ GIV @ s__Giving) & 
      (s__instance @ PCH @ s__PayCheck) & 
      (s__patient @ GIV @ PCH @ W1) &
      (s__destination @ GIV @ s__Bill @ W1)) => (
          (accreln3 @ s__confersObligation @ s__USG @ s__Bill @ W1 @ W2) => 
            ( ?[TAX: $i] : (
              (s__instance @ TAX @ s__Tax) & 
              (s__origin @ TAX @ s__Bill @ W2))))))).

% Obligation 2: "US Gov confers on Bill, that if Bill flies to moon, it 
% is obligatory he gets paycheck"
%(=>
%  (and 
%    (instance ?FLY Flying) 
%    (instance ?BILL Human) 
%    (instance ?MOON Moon)
%    (instance ?USG USGovernment)
%    (agent ?FLY ?BILL)
%    (destination ?FLY ?MOON))
%  (confersObligation ?USG Bill  
%    (exists (?G ?P)
%      (and 
%        (instance ?G Giving)
%        (instance ?P PayCheck)
%        (patient ?G ?P)
%        (destination ?G ?BILL)))))
thf(obligation2_must_be_paid, axiom,
  ![W1:w, W2: w] : 
  ( ![FLY: $i, MOON: $i] : (( 
      (s__instance @ FLY @ s__Flying) & 
      (s__instance @ MOON @ s__Moon) & 
      (s__agent @ FLY @ s__Bill @ W1) &
      (s__destination @ FLY @ MOON @ W1)) => (
          (accreln3 @ s__confersObligation @ s__USG @ s__Bill @ W1 @ W2) => 
            ( ?[G: $i, P: $i] : (
              (s__instance @ G @ s__Giving) & 
              (s__instance @ P @ s__PayCheck) & 
              (s__patient @ G @ P @ W2) & 
              (s__destination @ G @ s__Bill @ W2))))))).  
  
% Option A: "Bill flies to the moon"
% (exists (?FLY ?MOON) 
%   (and 
%     (instance ?FLY Flying)
%     (instance ?MOON Moon)
%     (agent ?FLY Bill)
%     (destination ?FLY ?MOON)))
thf(fact_flies_to_moon, axiom, (
  ?[FLY:$i, MOON:$i] : (
    ((s__instance @ FLY @ s__Flying) & 
    (s__instance @ MOON @ s__Moon) &
    (s__agent @ FLY @ s__Bill @ cw) & 
    (s__destination @ FLY @ MOON @ cw))))).

% Option B: "Bill does not fly to the moon"
% (not (exists (?FLY ?GS)
%   (and 
%     (instance ?FLY Flying)
%     (instance ?GS GroceryStore)
%     (agent ?FLY Bill)
%     (destination ?FLY ?GS))))
%thf(fact_does_not_fly, axiom, (
%  ~?[FLY:$i, MOON:$i] : (
%    ((s__instance @ FLY @ s__Flying) & 
%    (s__instance @ MOON @ s__Moon) &
%    (s__agent @ FLY @ s__Bill @ cw) & 
%    (s__destination @ FLY @ MOON @ cw))))).
    
% Conjecture: "Therefore, USG confers on Bill, that he must get taxed" 
% (confersObligation ?USG Bill 
%   (exists (?TAX)
%     (and 
%       (instance ?TAX Tax)
%       (origin ?TAX Bill))))  
thf(conjecture_he_get_taxed, conjecture, (
  ?[Wx: w, USG: $i] : (
    (accreln3 @ s__confersObligation @ s__USG @ s__Bill @ cw @ Wx) &
    (?[TAX: $i] : (
        (s__instance @ TAX @ s__Tax) & 
        (s__origin @ TAX @ s__Bill @ Wx)))))).  
