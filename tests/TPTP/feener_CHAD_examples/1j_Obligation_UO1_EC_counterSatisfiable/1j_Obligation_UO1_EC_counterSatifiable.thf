% CF 
% 1j_Obligation_UO1_EC_counterSatisfiable.thf
% Based on example 1G (with old optB) but with optB = ~optA. 
% This is to go back and test to see how D4 handles on a 
% universal Obligation on Negative option.

% Option A: Bill meets obligation 
% Results under System ...
% K (0, distribution)   : 
% D (1, serial)         : 
% D4                    : 
% D45                   : 
% T (2, reflexive)      : 
% B (3, r and symmetric): 
% S4 (r and trans)      : 
% S5 (r and Euclid)     : 
% Summary of findings: 

% Option B: Does not meet obligation 
% Results under System ...
% K (0, distribution)   : 
% D (1, serial)         : 
% D4                    : 
% D45                   : 
% T (2, reflexive)      : 
% B (3, r and symmetric): 
% S4 (r and trans)      : 
% S5 (r and Euclid)     : 
% Summary of findings: 

%%%%%%%%%%%%%%%%%%%%%%%%%% Pre-System Setup %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
thf(worlds_tp,type, w: $tType).
thf(cw_tp,type, cw: w).
thf(modals_tp,type, m: $tType).
thf(obligation_tp,type, s__Obligation: m).          % obligation modality
%thf(permission_tp, type, s__Permission: m).
%thf(prohibition_tp, type, s__Prohibition: m).
thf(accreln1_tp,type, accreln1: m > w > w > $o ).
thf(accreln2_tp,type, accreln2: m > $i > w > w > $o ).
thf(accreln3_tp,type, accreln3: m > $i > $i > w > w > $o ).

%%%%%%%%%%%%%%%%%%%%%% Systems: Under Obligation %%%%%%%%%%%%%%%%%%%%%%%%%%%
% 0. K: distribution
% [Nothing to implement] 

% 1. D: serial 
thf(serial_obligation, axiom,
  ![W1:w]: ?[W2:w]:
    (accreln1 @ s__Obligation @ W1 @ W2)).

% 2. T: reflexive
%thf(reflexive_obligation, axiom,
%  ![W:w]:(
%    (accreln1 @ s__Obligation @ W @ W))).

% 3. B: symmetric (if W1 accesses W2 then W2 accesses W1)
% NOTE: B is done with T 
%thf(symmetric_obligation, axiom,
%  ![W1: w, W2: w] :
%    ((accreln1 @ s__Obligation @ W1 @ W2) 
%      => (accreln1 @ s__Obligation @ W2 @ W1))).

% 4. S4: transitive (if W1->W2 and W2->W3 then W1->W3)
% NOTE: S4 is usually T + transitive; enable reflexive_obligation and this transitive axiom
thf(transitive_obligation, axiom,
  ![W1: w, W2: w, W3: w] :
    (((accreln1 @ s__Obligation @ W1 @ W2) &
      (accreln1 @ s__Obligation @ W2 @ W3))
     => (accreln1 @ s__Obligation @ W1 @ W3))).

% 5. S5: Euclidean (if W1->W2 and W1->W3 then W2->W3)
% NOTE: S5 is commonly given as T + Euclidean; enable reflexive_obligation and this euclid axiom
%thf(euclid_obligation, axiom,
%  ![W1: w, W2: w, W3: w] :
%    (((accreln1 @ s__Obligation @ W1 @ W2) &
%      (accreln1 @ s__Obligation @ W1 @ W3))
%     => (accreln1 @ s__Obligation @ W2 @ W3))).

      
%%%%%%%%%%%%%%%%%%%%%%%%%%% End: Systems-O %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Relations: 
thf(instance_t, type, s__instance:($i > $i > $o)).
thf(agent_t, type, s__agent:($i > $i > w > $o)).
thf(patient_t, type, s__patient: ($i > $i > w > $o)).
thf(destination_t, type, s__destination: ($i > $i > w > $o)).

% Terms: 
thf(flying_t, type, s__Flying: $i).
thf(human_t, type, s__Human: $i).
thf(grocerystore_t, type, s__GroceryStore: $i).
thf(moon_t, type, s__Moon: $i).
thf(giving_t, type, s__Giving: $i).
thf(paycheck_t, type, s__PayCheck: $i).

% Globals: 
thf(bill_t, type, s__Bill: $i).
thf(bill_always_human, axiom, (
  s__instance @ s__Bill @ s__Human)).

% Distinctness: 
thf(dist_moon_gs, axiom, ~(s__Moon = s__GroceryStore)).
thf(dist_moon_flying, axiom, ~(s__Moon = s__Flying)).
thf(dist_moon_giving, axiom, ~(s__Moon = s__Giving)).
thf(dist_moon_paycheck, axiom, ~(s__Moon = s__PayCheck)).
thf(dist_moon_human, axiom, ~(s__Moon = s__Human)).
thf(dist_gs_flying, axiom, ~(s__GroceryStore = s__Flying)).
thf(dist_gs_giving, axiom, ~(s__GroceryStore = s__Giving)).
thf(dist_gs_paycheck, axiom, ~(s__GroceryStore = s__PayCheck)).
thf(dist_gs_human, axiom, ~(s__GroceryStore = s__Human)).
thf(dist_flying_giving, axiom, ~(s__Flying = s__Giving)).
thf(dist_flying_paycheck, axiom, ~(s__Flying = s__PayCheck)).
thf(dist_flying_human, axiom, ~(s__Flying = s__Human)).
thf(dist_giving_paycheck, axiom, ~(s__Giving = s__PayCheck)).
thf(dist_giving_human, axiom, ~(s__Giving = s__Human)).
thf(dist_paycheck_human, axiom, ~(s__PayCheck = s__Human)).

% Obligation 1: "It is obligatory for Bill to fly to the moon"
% (modalAttribute 
%   (exists (?FLY ?MOON)
%     (and
%       (instance ?FLY Flying)
%       (instance ?MOON Moon) 
%       (agent ?FLY Bill)
%       (destination ?FLY ?MOON))) Obligation)
thf(obligation1_bill_fly, axiom,
      ! [W1: w, W2: w] : 
        ( (accreln1 @ s__Obligation @ W1 @ W2)
          => ?[FLY:$i, MOON:$i] :
               ( (s__instance @ FLY @ s__Flying) &
                 (s__instance @ MOON @ s__Moon) &
                 (s__agent @ FLY @ s__Bill @ W2) &
                 (s__destination @ FLY @ MOON @ W2) ) ) ).

% Obligation 2: "If Bill flies to moon, it is obligatory he gets paycheck"
%(=>
%  (and 
%    (instance ?FLY Flying) 
%    (instance ?BILL Human) 
%    (instance ?MOON Moon)
%    (agent ?FLY ?BILL)
%    (destination ?FLY ?MOON))
%  (modalAttribute 
%    (exists (?G ?P)
%      (and 
%        (instance ?G Giving)
%        (instance ?P PayCheck)
%        (patient ?G ?P)
%        (destination ?G ?BILL)))))
thf(obligation2_must_be_paid, axiom,
  ![W1:w, W2: w] : 
  ( ![FLY: $i, MOON: $i] : (( 
      (s__instance @ FLY @ s__Flying) & 
      (s__instance @ MOON @ s__Moon) & 
      (s__agent @ FLY @ s__Bill @ W1) &
      (s__destination @ FLY @ MOON @ W1)) => (
          (accreln1 @ s__Obligation @ W1 @ W2) => 
            ( ?[G: $i, P: $i] : (
              (s__instance @ G @ s__Giving) & 
              (s__instance @ P @ s__PayCheck) & 
              (s__patient @ G @ P @ W2) & 
              (s__destination @ G @ s__Bill @ W2))))))).             
  
% Option A: "Bill flies to the moon"
% (exists (?FLY ?MOON)
%   (and 
%     (instance ?FLY Flying) 
%     (instance ?MOON Moon) 
%     (agent ?FLY Bill)
%     (destination ?FLY ?MOON)))
%thf(fact_flies_to_moon, axiom, (
%  ?[FLY:$i, MOON:$i] : (
%    ((s__instance @ FLY @ s__Flying) & 
%    (s__instance @ MOON @ s__Moon) &
%    (s__agent @ FLY @ s__Bill @ cw) & 
%    (s__destination @ FLY @ MOON @ cw))))).

% Option B: "Bill flies to the grocerystore"
% (exists (?FLY ?GS) 
%   (and 
%     (instance ?FLY Flying) 
%     (instance ?GS GroceryStore) 
%     (agent ?FLY Bill)
%     (destination ?FLY ?GS)))
thf(fact_does_not_fly_moon, axiom, (
  ~?[FLY:$i, MOON:$i] : (
    ((s__instance @ FLY @ s__Flying) & 
    (s__instance @ MOON @ s__Moon) &
    (s__agent @ FLY @ s__Bill @ cw) & 
    (s__destination @ FLY @ MOON @ cw))))).
    
% Conjecture: "Therefore, Bill must get paycheck" 
% (modalAttribute 
%   (exists (?GIV ?PCH) 
%    (and 
%     (instance ?GIV Giving)
%     (instance ?PCH PayCheck) 
%     (patient ?GIV ?PCH)
%     (destination ?GIV Bill))) Obligation)
thf(conjecture_he_get_paycheck, conjecture, (
  ?[Wx: w] : (
    (accreln1 @ s__Obligation @ cw @ Wx) & 
    ( ?[GIV: $i, PCH: $i] : (
        (s__instance @ GIV @ s__Giving) & 
        (s__instance @ PCH @ s__PayCheck) & 
        (s__patient @ GIV @ PCH @ Wx) & 
        (s__destination @ GIV @ s__Bill @ Wx)))))).
