; Christopher Feener
; Permission_KIF.kif
; From KIF comments inside 2C (existential-conjecture and non-chained)

; Permission 1: "If Bill has drivers license, permitted to park in lot"
 (=> 
   (and
     (instance ?DL DriversLicense)
     (possesses Bill ?DL))
   (modalAttribute 
     (exists (?PARK ?LOT)
       (and 
         (instance ?PARK Parking)
         (instance ?LOT ParkingLot)
         (agent ?PARK Bill)
         (located ?PARK ?LOT))) Permission))
;thf(permission1_to_park, axiom,
;  ![W1:w, W2: w] : 
;  ( ![DL: $i] : (( 
;      (s__instance @ DL @ s__DriversLicense) & 
;      (s__possesses @ s__Bill @ DL @ W1)) => (
;          (accreln1 @ s__Permission @ W1 @ W2) => 
;            ( ?[PARK: $i, LOT: $i] : (
;              (s__instance @ PARK @ s__Parking) & 
;              (s__instance @ LOT @ s__ParkingLot) & 
;              (s__agent @ PARK @ s__Bill @ W2) &
;              (s__located @ PARK @ LOT @ W2))))))).
              
; NOTE: Permission 2 has been removed 

; Option A: "Bill has drivers license"
 (exists (?DL)
   (and 
     (instance ?DL DriversLicense)
     (possesses Bill ?DL)))
;thf(fact_has_license, axiom,
;  ?[DL: $i]: (
;    ((s__instance @ DL @ s__DriversLicense) & 
;    (s__possesses @ s__Bill @ DL @ cw)))).
      
; Option B: No license 
 (not (exists (?DL)
   (and 
     (instance ?DL DriversLicense)
     (possesses Bill ?DL))))
;thf(fact_no_license, axiom,
;  ~?[DL: $i]: (
;    ((s__instance @ DL @ s__DriversLicense) & 
;    (s__possesses @ s__Bill @ DL @ cw)))).

; Conjecture: "Therefore, Bill is permitted to park"
 (modalAttribute 
   (exists (?PARK ?LOT)
     (and 
       (instance ?PARK Parking)
       (instance ?LOT ParkingLot)
       (located ?PARK ?LOT)
       (agent ?PARK Bill))) Permission))
