; CF 
; 1c_o_parallel.kif

; Obligation 1: "It is obligatory for Bill to fly to the moon"
; NOTABLE RESULT: This bypasses the fact-axiom for negative option (B) and 
; Systems T and higher 
 (modalAttribute 
   (exists (?FLY ?MOON)
     (and 
       (instance ?FLY Flying)
       (instance ?MOON Moon)
       (agent ?FLY Bill)
       (destination ?FLY ?MOON))))
       
; Obligation 2: "If Bill flies to moon, it is obligatory he gets paycheck"
(=>
  (and 
    (instance ?FLY Flying) 
    (instance ?BILL Human) 
    (instance ?MOON Moon)
    (agent ?FLY ?BILL)
    (destination ?FLY ?MOON))
  (modalAttribute 
    (exists (?G ?P)
      (and 
        (instance ?G Giving)
        (instance ?P PayCheck)
        (patient ?G ?P)
        (destination ?G ?BILL)))))

;;;;;;;;;;;;;;;;;;;;;;;;; OPTIONS (toggle these) ;;;;;;;;;;;;;;;;;;;;;;;;;;

; Option A: "Bill flies to the moon"
 (exists (?FLY ?MOON) 
   (and 
     (instance ?FLY Flying)
     (instance ?MOON Moon)
     (agent ?FLY Bill)
     (destination ?FLY ?MOON)))
     
; Option B: "Bill does not fly to the moon"
 (not (exists (?FLY ?MOON) 
   (and 
     (instance ?FLY Flying)
     (instance ?MOON Moon)
     (agent ?FLY Bill)
     (destination ?FLY ?MOON))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; end options ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; Conjecture: "Therefore, Bill must get paycheck" 
; accessibility relation added 
 (modalAttribute 
   (exists (?GIV ?PCH)
     (and 
       (instance ?GIV Giving)
       (instance ?PCH PayCheck)
       (patient ?GIV ?PCH)
       (destination ?GIV Bill))) Obligation) 