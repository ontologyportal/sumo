; CF
; 1e_o_existnhops.kif

; Obligation 1: "If Bill gets a paycheck, he must pay taxes"
(=> 
  (and 
    (instance ?GIV Giving) 
    (instance ?PCH PayCheck)
    (patient ?GIV ?PCH) 
    (destination ?GIV Bill))
  (modalAttribute 
    (exists (?TAX) 
      (and 
        (instance ?TAX Tax)
        (origin ?TAX Bill))) Obligation))

; Obligation 2: "If Bill flies to moon, it is obligatory he gets paycheck"
(=>
  (and 
    (instance ?FLY Flying) 
    (instance ?BILL Human) 
    (instance ?MOON Moon)
    (agent ?FLY ?BILL)
    (destination ?FLY ?MOON))
  (modalAttribute 
    (exists (?G ?P)
      (and 
        (instance ?G Giving)
        (instance ?P PayCheck)
        (patient ?G ?P)
        (destination ?G ?BILL)))))

; Toggle options: 
        
; Option A: "Bill flies to the moon"
 (exists (?FLY ?MOON) 
   (and 
     (instance ?FLY Flying)
     (instance ?MOON Moon)
     (agent ?FLY Bill)
     (destination ?FLY ?MOON)))
     
; Option B: "Bill does not"
 (not (exists (?FLY ?MOON) 
   (and 
     (instance ?FLY Flying)
     (instance ?MOON Moon)
     (agent ?FLY Bill)
     (destination ?FLY ?MOON))))
     
; Conjecture: "Therefore, obligatory that Bill must get taxed" 
; This is being done with 2 hops to force System D to work 
; NOTE: Not sure about this SUMO 
(modalAttribute  
 (modalAttribute 
   (exists (?TAX)
     (and 
       (instance ?TAX Tax)
       (origin ?TAX Bill))) Obligation) Obligation)      