; CF 
; 4d_o_then_p_salo_2hopconj.kif

; Obligation 1: "If Bill gets a paycheck, must pay taxes"
(=>
  (and
    (instance ?PC PayCheck)
    (destination ?PC Bill))
  (modalAttribute 
    (exists (?G ?T)
      (and
        (instance ?G Giving)
        (instance ?T Tax)
        (agent ?G Bill)
        (patient ?G ?T))) Obligation))

; Obligation 2: "If pay taxes, must drive to office"
(=> 
  (and
    (instance ?G Giving)
    (instance ?T Tax)
    (agent ?G Bill)
    (patient ?G ?T))
  (modalAttribute 
    (exists (?D ?OB) 
      (and 
        (instance ?D Driving)
        (instance ?OB OfficeBuilding)
        (agent ?D Bill)
        (destination ?D ?OB))) Obligation))

; Permission: "If Bill drives to office, may park in lot" 
; Removed and behavior is incorporated into conjecture 

; Toggle options:

; Option A: "Bill gets a paycheck" 
(exists (?PC)
  (and
    (instance ?PC PayCheck)
    (destination ?PC Bill)))

; Option B: "Bill doesn't" 
(not (exists (?PC)
  (and
    (instance ?PC PayCheck)
    (destination ?PC Bill))))

; Conjecture: "Therefore, Bill must be allowed to drive to office"
 (modalAttribute 
  (modalAttribute 
    (exists (?D ?OB) 
      (and 
        (instance ?D Driving)
        (instance ?OB OfficeBuilding)
        (agent ?D Bill)
        (destination ?D ?OB))) Permission) Obligation)