; CF
; 1g_o_uo1_existconj.kif

; Obligation 1: "It is obligatory for Bill to fly to the moon"
 (modalAttribute 
   (exists (?FLY ?MOON)
     (and
       (instance ?FLY Flying)
       (instance ?MOON Moon) 
       (agent ?FLY Bill)
       (destination ?FLY ?MOON))) Obligation)
       
; Obligation 2: "If Bill flies to moon, it is obligatory he gets paycheck"
(=>
  (and 
    (instance ?FLY Flying) 
    (instance ?BILL Human) 
    (instance ?MOON Moon)
    (agent ?FLY ?BILL)
    (destination ?FLY ?MOON))
  (modalAttribute 
    (exists (?G ?P)
      (and 
        (instance ?G Giving)
        (instance ?P PayCheck)
        (patient ?G ?P)
        (destination ?G ?BILL)))))

; Toggle options:
        
; Option A: "Bill flies to the moon"
 (exists (?FLY ?MOON)
   (and 
     (instance ?FLY Flying) 
     (instance ?MOON Moon) 
     (agent ?FLY Bill)
     (destination ?FLY ?MOON)))
     
; Option B: "Bill does not"
 (not (exists (?FLY ?MOON)
   (and 
     (instance ?FLY Flying) 
     (instance ?MOON Moon) 
     (agent ?FLY Bill)
     (destination ?FLY ?MOON))))
     
; Conjecture: "Therefore, Bill must get paycheck" 
 (modalAttribute 
   (exists (?GIV ?PCH) 
    (and 
     (instance ?GIV Giving)
     (instance ?PCH PayCheck) 
     (patient ?GIV ?PCH)
     (destination ?GIV Bill))) Obligation)