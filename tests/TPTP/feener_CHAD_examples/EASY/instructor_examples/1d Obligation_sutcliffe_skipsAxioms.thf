% CF
% Obligation_sutcliffe.thf
% This is the code from the email
% Error: Runs, but no axioms used 

% Option A: Bill meets obligation
% Results under System ...
% K (0, distribution)   :
% D (1, serial)         :
% T (2, reflexive)      :
% B (3, r and symmetric):
% S4 (r and trans)      :
% S5 (r and Euclid)     :

% Option B: Does not meet obligation
% Results under System ...
% K (0, distribution)   :
% D (1, serial)         :
% T (2, reflexive)      :
% B (3, r and symmetric):
% S4 (r and trans)      :
% S5 (r and Euclid)     :

%%%%%%%%%%%%%%%%%%%%%%%%%% Pre-System Setup %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
thf(worlds_tp,type,
    w: $tType ).

thf(cw_tp,type,
    cw: w ).

thf(modals_tp,type,
    m: $tType ).

thf(obligation_tp,type,
    s__Obligation: m ).

% obligation modality
%thf(permission_tp, type, s__Permission: m).
%thf(prohibition_tp, type, s__Prohibition: m).
thf(accreln1_tp,type,
    accreln1: m > w > w > $o ).

thf(accreln2_tp,type,
    accreln2: m > $i > w > w > $o ).

thf(accreln3_tp,type,
    accreln3: m > $i > $i > w > w > $o ).

% For later: accreln3-to-accreln1 will need to have repeated systems

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Systems %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% 0. K: distribution
% [Nothing to implement]

% 1. D: serial
%thf(serial_deontic, axiom,
%  ![W1: w]:?[W2: w]:![F: w>$o]:(
%    (((accreln1 @ s__Obligation @ W1 @ W2) => (F @ W2))))).

% 1a. D: serial 2
%thf(serial_deontic, axiom,
%  ![W1:w]: ?[W2:w]:
%    (accreln1 @ s__Obligation @ W1 @ W2)).

% 2. T: reflexive
thf(reflexive_deontic,axiom,
    ! [W: w] : ( accreln1 @ s__Obligation @ W @ W ) ).

% 3. B: symmetric
%thf(symmetric_deontic, axiom,
%  ![W1:w,W2:w,F:w>$o]:(
%    ((accreln1 @ s__Obligation @ W1 @ W2) => (F @ W2)) =>
%    ((accreln1 @ s__Obligation @ W2 @ W1) => (F @ W1)))).

% 4. S4: r and transitive
%thf(transitive_deontic,axiom,
%  ![W1:w, W2:w, W3:w, F:w>$o]:(
%    (((accreln1 @ s__Obligation @ W1 @ W2) => (F @ W2)) &
%    ((accreln1 @ s__Obligation @ W2 @ W3) => (F @ W3))) =>
%      ((accreln1 @ s__Obligation @ W1 @ W3) => (F @ W3)))).

% 5. System S5: Euclidean
%thf(euclid_deontic,axiom,
%  ![W1:w, W2:w, W3:w, F:w>$o]:(
%    (((accreln1 @ s__Obligation @ W1 @ W2) => (F @ W2)) &
%    ((accreln1 @ s__Obligation @ W1 @ W3) => (F @ W3))) =>
%      ((accreln1 @ s__Obligation @ W2 @ W3) => (F @ W3)))).
%%%%%%%%%%%%%%%%%%%%%%%%%%% End of Systems %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Relations:
thf(instance_t,type,
    s__instance: $i > $i > $o ).

thf(agent_t,type,
    s__agent: $i > $i > w > $o ).

thf(patient_t,type,
    s__patient: $i > $i > w > $o ).

thf(destination_t,type,
    s__destination: $i > $i > w > $o ).

% Terms:
thf(flying_t,type,
    s__Flying: $i ).

thf(human_t,type,
    s__Human: $i ).

thf(grocerystore_t,type,
    s__GroceryStore: $i ).

thf(moon_t,type,
    s__Moon: $i ).

thf(giving_t,type,
    s__Giving: $i ).

thf(paycheck_t,type,
    s__PayCheck: $i ).

% Globals:
thf(bill_t,type,
    s__Bill: $i ).

thf(bill_always_human,axiom,
    s__instance @ s__Bill @ s__Human ).

%thf(w1_t, type, s__W1: w).
%thf(w2_t, type, s__W2: w).

% Obligation 1: "It is obligatory for Bill to fly to the moon"
thf(obligatory_bill_fly_modal,axiom,
    ! [W1: w,W2: w] :
      ( ( accreln1 @ s__Obligation @ W1 @ W2 )
     => ? [FLY: $i,MOON: $i] :
          ( ( s__instance @ FLY @ s__Flying )
          & ( s__instance @ MOON @ s__Moon )
          & ( s__agent @ FLY @ s__Bill @ W2 )
          & ( s__destination @ FLY @ MOON @ W2 ) ) ) ).

% Obligation 2: "If Bill flies to moon, it is obligatory he gets paycheck"
%(=>
%  (and
%    (instance ?FLY Flying)
%    (instance ?BILL Human)
%    (instance ?MOON Moon)
%    (agent ?FLY ?BILL)
%    (destination ?FLY ?MOON))
%  (modalAttribute
%    (exists (?G ?P)
%      (and
%        (instance ?G Giving)
%        (instance ?P PayCheck)
%        (patient ?G ?P)
%        (destination ?G ?BILL)))))
thf(must_be_paid,axiom,
    ! [W1: w,W2: w] :
      ( ? [FLY: $i,MOON: $i] :
          ( ( s__instance @ FLY @ s__Flying )
          & ( s__instance @ MOON @ s__Moon )
          & ( s__agent @ FLY @ s__Bill @ W1 )
          & ( s__destination @ FLY @ MOON @ W1 ) )
     => ( ( accreln1 @ s__Obligation @ W1 @ W2 )
       => ? [G: $i,P: $i] :
            ( ( s__instance @ G @ s__Giving )
            & ( s__instance @ P @ s__PayCheck )
            & ( s__patient @ G @ P @ W2 )
            & ( s__destination @ P @ s__Bill @ W2 ) ) ) ) ).

% Option A: "Bill flies to the moon"
thf(flies_to_moon,axiom,
    ? [FLY: $i,MOON: $i] :
      ( ( s__instance @ FLY @ s__Flying )
      & ( s__instance @ MOON @ s__Moon )
      & ( s__agent @ FLY @ s__Bill @ cw )
      & ( s__destination @ FLY @ MOON @ cw ) ) ).

% Conjecture: "Therefore, Bill must get paycheck"
% accessibility relation added
thf(obligatory_he_get_paycheck,conjecture,
    ! [W1: w] :
      ( ( accreln1 @ s__Obligation @ cw @ W1 )
     => ? [G: $i,P: $i] :
          ( ( s__instance @ G @ s__Giving )
          & ( s__instance @ P @ s__PayCheck )
          & ( s__patient @ G @ P @ W1 )
          & ( s__destination @ P @ s__Bill @ W1 ) ) ) ).

