; CF
; 2a_p_chained_univconj.kif

; Permission 1: "If Bill has drivers license, permitted to park in lot"
 (=> 
   (and
     (instance ?DL DriversLicense)
     (possesses Bill ?DL))
   (modalAttribute 
     (exists (?PARK ?LOT)
       (and 
         (instance ?PARK Parking)
         (instance ?LOT ParkingLot)
         (agent ?PARK Bill)
         (located ?PARK ?LOT))) Permission))

; Permission 2: "If Bill parks in the lot, Bill is permitted to be reimbursed"
 (=> 
   (and
      (instance ?PARK Parking)
      (instance ?LOT ParkingLot)
      (agent ?PARK Bill)
      (located ?PARK ?LOT))
   (modalAttribute 
     (exists (?REIM)
       (and 
         (instance ?REIM Reimbursement)
         (destination ?REIM Bill))) Permission))

; Toggle options: 

; Option A: "Bill has drivers license"
 (exists (?DL)
   (and 
     (instance ?DL DriversLicense)
     (possesses Bill ?DL)))

; Option B: No license 
; (not (exists (?DL)
;   (and 
;     (instance ?DL DriversLicense)
;     (possesses Bill ?DL))))

; Conjecture: "Therefore, Bill is permitted to get reimbursed"
 (modalAttribute 
   (exists (?REIM)
     (and 
       (instance ?REIM Reimbursement)
       (destination ?REIM Bill))))