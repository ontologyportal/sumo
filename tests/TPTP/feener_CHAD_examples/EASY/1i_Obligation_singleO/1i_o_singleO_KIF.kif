; CF 
; 1i_o_singleO.kif

; Obligation 1 removed to test single obligation firing under systems 

; Obligation 2: "If Bill flies to moon, it is obligatory he gets paycheck"
(=>
  (and 
    (instance ?FLY Flying) 
    (instance ?BILL Human) 
    (instance ?MOON Moon)
    (agent ?FLY ?BILL)
    (destination ?FLY ?MOON))
  (modalAttribute 
    (exists (?G ?P)
      (and 
        (instance ?G Giving)
        (instance ?P PayCheck)
        (patient ?G ?P)
        (destination ?G ?BILL))) Obligation))

; Toggle options:         
        
; Option A: "Bill flies to the moon"
 (exists (?FLY ?MOON) 
   (and 
     (instance ?FLY Flying)
     (instance ?MOON Moon)
     (agent ?FLY Bill)
     (destination ?FLY ?MOON)))
     
; Option B: "Bill does not"
 (not (exists (?FLY ?MOON) 
   (and 
     (instance ?FLY Flying)
     (instance ?MOON Moon)
     (agent ?FLY Bill)
     (destination ?FLY ?MOON))))
     
; Conjecture: "Therefore, Bill must get paycheck" 
; accessibility relation added 
 (modalAttribute 
   (exists (?TAX)
     (and 
       (instance ?TAX Tax)
       (origin ?TAX Bill))) Obligation)