; CF
; 4_o_then_p.kif

; Obligation 1: "If Bill gets a paycheck, must pay taxes"
(=>
  (and
    (instance ?PC PayCheck)
    (destination ?PC Bill))
  (modalAttribute 
    (exists (?G ?T)
      (and
        (instance ?G Giving)
        (instance ?T Tax)
        (agent ?G Bill)
        (patient ?G ?T))) Obligation))

; Obligation 2: "If pay taxes, must drive to office"
(=> 
  (and
    (instance ?G Giving)
    (instance ?T Tax)
    (agent ?G Bill)
    (patient ?G ?T))
  (modalAttribute 
    (exists (?D ?OB) 
      (and 
        (instance ?D Driving)
        (instance ?OB OfficeBuilding)
        (agent ?D Bill)
        (destination ?D ?OB))) Obligation))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;; OPTIONS (toggle these) ;;;;;;;;;;;;;;;;;;;;;;;
        
; Option A: "Bill gets a paycheck" 
(exists (?PC)
  (and
    (instance ?PC PayCheck)
    (destination ?PC Bill)))
    
; Option B: "Bill doesn't" 
;(not (exists (?PC)
;  (and
;    (instance ?PC PayCheck)
;    (destination ?PC Bill))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; end options ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
    
; Conjecture: "Therefore, Bill may drive to the office"
 (modalAttribute 
    (exists (?D ?OB) 
      (and 
        (instance ?D Driving)
        (instance ?OB OfficeBuilding)
        (agent ?D Bill)
        (destination ?D ?OB))) Permission)
