; CF
; 2_permission.kif

; Permission 1: "If Bill has drivers license, permitted to park in lot"
 (=> 
   (and
     (instance ?DL DriversLicense)
     (possesses Bill ?DL))
   (modalAttribute 
     (exists (?PARK ?LOT)
       (and 
         (instance ?PARK Parking)
         (instance ?LOT ParkingLot)
         (agent ?PARK Bill)
         (located ?PARK ?LOT))) Permission))
         
; NOTE: Permission 2 has been removed since no chaining 

; Toggle options: 

; Option A: "Bill has drivers license"
 (exists (?DL)
   (and 
     (instance ?DL DriversLicense)
     (possesses Bill ?DL)))
     
; Option B: No license 
 (not (exists (?DL)
   (and 
     (instance ?DL DriversLicense)
     (possesses Bill ?DL))))
     
; Conjecture: "Therefore, Bill is permitted to park"
 (modalAttribute 
   (exists (?PARK ?LOT)
     (and 
       (instance ?PARK Parking)
       (instance ?LOT ParkingLot)
       (located ?PARK ?LOT)
       (agent ?PARK Bill))) Permission))
