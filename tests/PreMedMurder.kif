; if a person desires someone dead ahead of murdering them, it's premeditated murder

; from SUMO
(=>
    (and
        (holdsDuring ?T
            (desires ?M
                (attribute ?V Dead)))
        (instance ?MURDER Murder)
        (agent ?MURDER ?M)
        (patient ?MURDER ?V)
        (earlier ?T
            (WhenFn ?MURDER)))
    (attribute ?MURDER Premeditated))
    
; Vito wanted Paulie dead in 1980

(holdsDuring (YearFn 1980)
  (desires Vito
    (attribute Paulie Dead)))
                
; Vito killed Paulie in 1982

(exists (?MVP)
  (and
    (instance ?MVP Murder)
    (agent ?MVP Vito)
    (patient ?MVP Paulie)
    (earlier (YearFn 1982)
      (WhenFn ?MVP))))
            
; If murder is premeditated the punishment is death

(=>
  (and
    (instance ?MURDER Murder)
    (agent ?MURDER ?M)
    (patient ?MURDER ?V)
    (attribute ?MURDER Premeditated))
  (exists (?E)
    (and
      (instance ?E Execution)
      (victim ?E ?M))))
      
; Does the government kill Vito?

(exists (?E)
  (and
    (instance ?E Execution)
    (victim ?E ?M)))

    
