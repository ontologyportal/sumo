(note TQG33)  ;; boolean version
(category general)

;; Commonsense reasoning: every physical object has some non-zero
;; positive mass.

(minLang tff)

(instance Animal33-1 Animal)

(=>
  (and
    (instance ?A Object)
    (weight ?A (MeasureFn ?N ?U)))
  (greaterThan ?N 0.0))
  
(query 
  (not (weight Animal33-1 (MeasureFn -100.0 PoundMass))))

(answer yes)


