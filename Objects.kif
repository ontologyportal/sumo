(=>
  (instance ?PS PruningShears)
  (exists (?H)
    (and
      (instance ?H Handle)
      (part ?H ?PS))))

(=>
  (instance ?PS PruningShears)
  (exists (?B1 ?B2)
    (and
      (instance ?B1 Blade)
      (instance ?B2 Blade)
      (part ?B1 ?PS)
      (part ?B2 ?PS)
      (not (equal ?B1 ?B2)))))

(=>
  (instance ?PS PruningShears)
  (exists (?SC)
    (and
      (instance ?SC Screw)
      (part ?SC ?PS))))

(=>
  (instance ?PS PruningShears)
  (hasPurpose ?PS
    (exists (?SHR ?PLANT)
