    (instrument ?WALK ?UMB))
  (located ?UMB ?PERSON))

(=>
  (instance ?UMB Umbrella)
  (exists (?R)
    (and
      (instance ?R Rod)
      (part ?R ?UMB))))

(=>
  (and
    (instance ?UMB Umbrella)
    (instance ?PROT Protecting)
    (instrument ?PROT ?UMB))
  (exists (?G ?H)
    (and
      (instance ?G Grabbing)
      (instance ?H Hand)
      (instrument ?G ?H)
      (patient ?G ?UMB))))

(=>
  (and
    (instance ?UMB Umbrella)
    (instance ?PROT Protecting)
    (instrument ?PROT ?UMB)
    (patient ?PROT ?PERSON))
  (orientation ?UMB ?PERSON Above))

(=>
  (instance ?UMB Umbrella)
  (hasPurpose ?UMB
    (exists (?PROT ?PERSON)
      (and
        (instance ?PROT Protecting)
